# ═══════════════════════════════════════════════
#  大模型 API 配置
#  将本文件复制为 .env，填入你的 API 密钥
# ═══════════════════════════════════════════════

# API Key（从大模型平台获取，如 DeepSeek / OpenAI 等）
API_KEY=sk-your-api-key-here

# API Base URL（OpenAI 兼容格式）
API_BASE_URL=https://api.deepseek.com

# 模型名称
MODEL_NAME=deepseek-chat
